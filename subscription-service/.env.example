POSTGRES_USER=axiom
POSTGRES_PASS=changeme_local_dev

REDIS_PASS=changeme_local_dev

# Default: point at your own remote/VPS Kafka broker over SASL_SSL
KAFKA_BOOTSTRAP_SERVERS=kafka.your-domain.com:9093
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="axiom" password="changeme_local_dev";

# Alternative: local Kafka via `docker compose --profile local-kafka up -d`
# KAFKA_BOOTSTRAP_SERVERS=localhost:9094
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_MECHANISM=
# KAFKA_SASL_JAAS_CONFIG=